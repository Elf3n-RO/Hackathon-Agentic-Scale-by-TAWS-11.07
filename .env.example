# Supabase (build-time, expuestas al navegador)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# n8n — en local Vite las usa el proxy; en Vercel configúralas también como N8N_* (servidor)
VITE_N8N_BASE_URL=https://primary-production-3b7c.up.railway.app
VITE_N8N_WEBHOOK_URL=https://primary-production-3b7c.up.railway.app/webhook/chat

# Serverless Vercel (recomendado; no hace falta el prefijo VITE_)
N8N_BASE_URL=https://primary-production-3b7c.up.railway.app
N8N_WEBHOOK_URL=https://primary-production-3b7c.up.railway.app/webhook/chat

# false = Supabase real | true = datos simulados
VITE_USE_MOCK=false
